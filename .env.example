# Tavily: real open-web debtor/context research.
TAVILY_API_KEY=
TAVILY_PROJECT=

# ClickHouse: real evidence/action/event writes.
CLICKHOUSE_URL=
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=recover_ai

# Stripe: test-mode Checkout payment link.
STRIPE_SECRET_KEY=
PUBLIC_BASE_URL=http://localhost:5173

# Slack: real notification using an incoming webhook.
SLACK_WEBHOOK_URL=

# Prometheux: optional executable ontology evaluation.
PROMETHEUX_ENGINE_URL=
PROMETHEUX_API_TOKEN=

# Demo defaults. The invoice is synthetic; this company/domain is only used
# as a public web context target for Tavily grounding.
DEMO_PUBLIC_COMPANY_NAME=ClickHouse
DEMO_PUBLIC_COMPANY_DOMAIN=clickhouse.com
